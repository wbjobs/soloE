# ==============================================================================
# P2P CDN 系统 Coturn TURN 服务器环境变量配置
# ==============================================================================
# 请复制此文件为 .env 并根据实际情况修改配置

# ------------------------------------------------------------------------------
# 网络配置
# ------------------------------------------------------------------------------

# TURN 服务器的公网 IP 地址（必须配置）
# 如果设置为 auto，启动时会自动检测
TURN_EXTERNAL_IP=auto

# TURN 监听端口（UDP/TCP）
TURN_LISTENING_PORT=3478

# TLS 监听端口（生产环境建议使用）
TURN_TLS_LISTENING_PORT=5349

# 中继端口范围（必须在防火墙中开放）
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# ------------------------------------------------------------------------------
# 认证配置
# ------------------------------------------------------------------------------

# 认证用户名（建议修改为复杂用户名）
TURN_USER=p2pcdn

# 认证密码（必须使用强密码！建议使用 16 位以上随机字符串）
# 生产环境请使用: openssl rand -hex 16 生成
TURN_PASSWORD=change_this_to_a_strong_password

# 认证域（通常使用你的域名）
TURN_REALM=p2p-cdn-system.com

# ------------------------------------------------------------------------------
# 性能配置
# ------------------------------------------------------------------------------

# 最大带宽限制 (bytes/sec)，0 表示不限制
TURN_MAX_BPS=0

# 单个用户最大带宽限制
TURN_MAX_BPS_PER_USER=10485760

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------

# 详细日志（生产环境建议关闭）
TURN_VERBOSE=true

# 日志文件路径
TURN_LOG_FILE=/var/log/turnserver/turnserver.log

# ------------------------------------------------------------------------------
# TLS 配置（生产环境必须配置）
# ------------------------------------------------------------------------------

# TLS 证书路径
# TURN_CERT=/etc/coturn/certificates/fullchain.pem

# TLS 私钥路径
# TURN_PKEY=/etc/coturn/certificates/privkey.pem

# ------------------------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------------------------

# 禁止的对等 IP 范围（用逗号分隔）
# DENY_PEER_IP=127.0.0.0-127.255.255.255,10.0.0.0-10.255.255.255

# 允许的对等 IP 范围（白名单优先）
# ALLOW_PEER_IP=0.0.0.0-255.255.255.255

# ------------------------------------------------------------------------------
# 高级配置
# ------------------------------------------------------------------------------

# 启用指纹
TURN_FINGERPRINT=true

# 长期凭证机制（推荐）
TURN_LT_CRED_MECH=true

# 其他命令行参数
# TURN_EXTRA_ARGS=
