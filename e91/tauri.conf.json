{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hover Translator",
  "version": "0.1.0",
  "identifier": "com.hovertranslator.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "../dist",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "floating-ball",
        "title": "Hover Translator",
        "width": 60,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "closable": false
      },
      {
        "label": "translate-result",
        "title": "Translation Result",
        "width": 400,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "minimizable": false,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": []
  }
}
